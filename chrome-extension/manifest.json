{
  "manifest_version": 3,
  "name": "Triton Smart-Scrape",
  "version": "1.0.0",
  "description": "Capture Canvas course content and send it to UCSD Course Agent for automatic calendar extraction.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Triton Smart-Scrape"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
      "https://canvas.ucsd.edu/*",
      "https://*.instructure.com/*"
      ],
      "js": ["content.js"]
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://*.instructure.com/*",
    "https://*.canvas.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ]
}
